{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug STM32G4 Bare-Metal",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/L6_Uart_DMA/build/firmware.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g4x.cfg"
            ],
            "gdbPath": "arm-none-eabi-gdb",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
        }
    ]
}